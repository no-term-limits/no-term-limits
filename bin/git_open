#!/usr/bin/env bash

function error_handler() {
  echo >&2 "Exited with BAD EXIT CODE '${2}' in ${0} script at line: ${1}."
  exit "$2"
}
trap 'error_handler ${LINENO} $?' ERR
set -o errtrace -o errexit -o nounset -o pipefail

# HELP: git: browse to repo in github or bitbucket. Opens the current branch's GitHub PR when one exists. Passing in --pr will open the compare page in github.

function github_pr_url_for_branch() {
  local branch="$1"
  local pr_url

  if ! command -v gh >/dev/null; then
    return 1
  fi

  if pr_url=$(gh pr view "$branch" --json url --jq .url 2>/dev/null) && [[ -n "$pr_url" ]]; then
    echo "$pr_url"
    return 0
  fi

  return 1
}

function git_base_branch() {
  local origin_head

  if origin_head=$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null); then
    echo "${origin_head#origin/}"
  elif has_main_branch; then
    echo "main"
  else
    echo "master"
  fi
}

directory_name=$(pwd)

file_full_path="${1:-}"
line_number="${2:-}"

open_compare_link="false"
open_repo_root="false"
open_pull_request_if_available="false"
if [[ -z "$file_full_path" ]]; then
  open_repo_root="true"
  open_pull_request_if_available="true"
  file_full_path="$directory_name"
elif [[ "$file_full_path" == "--pr" ]]; then
  open_compare_link="true"
  file_full_path="$directory_name"
elif [[ -f "$file_full_path" ]]; then
  directory_name=$(dirname "$file_full_path")
elif [[ -d "$file_full_path" ]]; then
  directory_name="$file_full_path"
fi
cd "$directory_name"

url_path=""
branch=$(git_branch)
base_branch=$(git_base_branch)
if [[ "$branch" == "$base_branch" ]]; then
  open_pull_request_if_available="false"
fi
git_url=$(git_url_of_current_directory)

git_root="$(git rev-parse --show-toplevel)"
relative_file=$(hot_sed -E "s|${git_root}||" <<<"$file_full_path" | sed -E 's|^/+||g')
if [[ "$open_repo_root" == "true" ]]; then
  relative_file=""
fi

project_path=$(perl -p -e "s|${NO_TERM_LIMITS_PROJECTS_DIR}||" <<<"$git_root")
dir_count=$(perl -p -e 's|/| |g' <<<"$project_path" | wc -w)
project_name=""
profile_arg=""
if [[ "$dir_count" -gt 2 ]]; then
  project_name=$(awk -F '/' '{print $3}' <<<"$project_path")
  profile=$(get_chrome_profile "${project_name}")
  if [[ -n "$profile" ]]; then
    profile_arg="--profile-directory=${profile}"
  fi
fi

if grep -q 'github.com' <<<"$git_url"; then
  if [[ "$open_compare_link" == "true" ]]; then
    url_path="${git_url}/compare/main...${branch}"
  elif [[ "$open_pull_request_if_available" == "true" ]] && pr_url=$(github_pr_url_for_branch "$branch"); then
    url_path="$pr_url"
  else
    url_path="/tree/${branch}/${relative_file}"
    if [[ -n "$line_number" ]]; then
      url_path="${url_path}#L${line_number}"
    fi
    url_path="${git_url}${url_path}"
  fi
elif grep -q 'bitbucket.org' <<<"$git_url"; then
  commit_hash=$(git rev-parse --verify HEAD)
  url_path="${git_url}src/${commit_hash}/${relative_file}?at=${branch}"
  if [[ -n "$line_number" ]]; then
    url_path="${url_path}#lines-${line_number}"
  fi
else
  # for bitbucket-server
  url_path="${git_url}browse/${relative_file}?at=${branch}"
  if [[ -n "$line_number" ]]; then
    url_path="${url_path}#${line_number}"
  fi
fi

open_url "${url_path}" "$profile_arg"
