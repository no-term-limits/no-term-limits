#!/usr/bin/env bash

set -e

# Find nvim config directory - prefer ~/.config/nvim for plugin installation
NVIM_CONFIG="$HOME/.config/nvim"

# Find manifest in dotfiles repo
if [[ -n "${NO_TERM_LIMITS_DIR:-}" ]]; then
  DOTFILES_NVIM="$NO_TERM_LIMITS_DIR/dotfiles_no_term_limits/config/nvim"
elif [[ -d "$HOME/no-term-limits/dotfiles_no_term_limits/config/nvim" ]]; then
  DOTFILES_NVIM="$HOME/no-term-limits/dotfiles_no_term_limits/config/nvim"
elif [[ -d "$HOME/projects/github/no-term-limits/dotfiles_no_term_limits/config/nvim" ]]; then
  DOTFILES_NVIM="$HOME/projects/github/no-term-limits/dotfiles_no_term_limits/config/nvim"
else
  echo "Error: Could not find dotfiles nvim directory"
  exit 1
fi

if [[ ! -d "$NVIM_CONFIG" ]]; then
  echo "Error: ~/.config/nvim does not exist. Run 'rcup -q' first."
  exit 1
fi

MANIFEST="$DOTFILES_NVIM/plugins.json"
PLUGIN_DIR="$NVIM_CONFIG/pack/plugins/start"

command_install() {
  echo "Installing to: $PLUGIN_DIR"
  echo "Using manifest: $MANIFEST"
  echo ""
  echo "Installing plugins from manifest..."
  mkdir -p "$PLUGIN_DIR"

  # Get list of plugins from manifest
  local plugins=$(jq -r '.plugins | keys[]' "$MANIFEST")

  for plugin_name in $plugins; do
    local repo=$(jq -r ".plugins[\"$plugin_name\"].repo" "$MANIFEST")
    local commit=$(jq -r ".plugins[\"$plugin_name\"].commit" "$MANIFEST")

    if [ ! -d "$PLUGIN_DIR/$plugin_name" ]; then
      echo "  Cloning $plugin_name..."
      git clone --quiet "https://github.com/$repo" "$PLUGIN_DIR/$plugin_name"
    else
      echo "  $plugin_name already exists"
    fi

    cd "$PLUGIN_DIR/$plugin_name"
    if [ "$commit" = "latest" ]; then
      echo "    Using latest commit"
    else
      echo "    Checking out commit: $commit"
      # Only fetch tags if commit looks like a tag (starts with v or contains dots)
      if [[ "$commit" =~ ^v[0-9] ]] || [[ "$commit" =~ \. ]]; then
        git fetch --tags --quiet 2>/dev/null || true
        git checkout --quiet "tags/$commit" 2>/dev/null || git checkout --quiet "$commit" 2>/dev/null
      else
        # Just checkout the commit hash directly
        git checkout --quiet "$commit" 2>/dev/null
      fi
    fi

    # Note: blink.cmp auto-downloads prebuilt binaries on tagged releases
    # If download fails or you're on main branch, run: vpm build-blink

    cd "$NVIM_CONFIG"
  done

  # Remove plugins not in manifest
  if [ -d "$PLUGIN_DIR" ]; then
    for installed_plugin in "$PLUGIN_DIR"/*; do
      if [ -d "$installed_plugin" ]; then
        plugin_name=$(basename "$installed_plugin")
        if ! echo "$plugins" | grep -q "^${plugin_name}$"; then
          echo "  Removing $plugin_name (not in manifest)"
          rm -rf "$installed_plugin"
        fi
      fi
    done
  fi

  echo ""
  echo "✓ All plugins installed!"

  # Install treesitter parsers
  echo ""
  echo "Installing treesitter parsers (this may take a minute)..."
  if command -v nvim >/dev/null 2>&1; then
    if nvim --headless "+lua if vim.fn.exists(':TSUpdate') == 2 then vim.cmd('TSUpdate') elseif vim.fn.exists(':TSUpdateSync') == 2 then vim.cmd('TSUpdateSync') else vim.cmd('cquit 1') end" +qall; then
      local parser_check
      parser_check=$(nvim --headless "+lua local missing={} for _,lang in ipairs({'python','javascript','typescript','tsx','json','yaml','bash','lua','vim','terraform','hcl'}) do if #vim.api.nvim_get_runtime_file('parser/' .. lang .. '.so', false) == 0 then table.insert(missing, lang) end end if #missing == 0 then print('OK') else print('MISSING:' .. table.concat(missing, ',')) end" +qall | tail -n1)
      if [[ "$parser_check" == "OK" ]]; then
        echo "✓ Treesitter parsers installed"
      else
        local missing_parsers="${parser_check#MISSING:}"
        if [[ "$parser_check" == MISSING:* ]]; then
          echo "Installing missing Treesitter parsers: $missing_parsers"
          if nvim --headless "+TSInstall ${missing_parsers//,/ }" +qall; then
            local parser_recheck
            parser_recheck=$(nvim --headless "+lua local missing={} for _,lang in ipairs({'python','javascript','typescript','tsx','json','yaml','bash','lua','vim','terraform','hcl'}) do if #vim.api.nvim_get_runtime_file('parser/' .. lang .. '.so', false) == 0 then table.insert(missing, lang) end end if #missing == 0 then print('OK') else print('MISSING:' .. table.concat(missing, ',')) end" +qall | tail -n1)
            if [[ "$parser_recheck" == "OK" ]]; then
              echo "✓ Treesitter parsers installed"
            else
              echo "⚠ Treesitter parser check failed after install: $parser_recheck"
              echo "  Run ':checkhealth nvim-treesitter' inside nvim"
            fi
          else
            echo "⚠ Treesitter parser install failed for: $missing_parsers"
            echo "  Run ':checkhealth nvim-treesitter' inside nvim"
          fi
        else
          echo "⚠ Treesitter parser check failed: $parser_check"
          echo "  Run ':checkhealth nvim-treesitter' inside nvim"
        fi
      fi
    else
      echo "⚠ Treesitter command not available or install failed. Run ':checkhealth nvim-treesitter' inside nvim"
    fi
  else
    echo "⚠ nvim not found. Run ':TSUpdate' inside nvim after setup"
  fi
}

command_update() {
  local plugin_name=$1

  if [ -z "$plugin_name" ]; then
    # Update all plugins
    echo "Updating all plugins..."
    local plugins=$(jq -r '.plugins | keys[]' "$MANIFEST")
    for plugin_name in $plugins; do
      update_single_plugin "$plugin_name"
    done
  else
    # Update single plugin
    update_single_plugin "$plugin_name"
  fi

  echo ""
  echo "✓ Update complete!"
}

update_single_plugin() {
  local plugin_name=$1
  local repo=$(jq -r ".plugins[\"$plugin_name\"].repo" "$MANIFEST" 2>/dev/null)

  if [ "$repo" = "null" ] || [ -z "$repo" ]; then
    echo "  Error: Plugin '$plugin_name' not found in manifest"
    return 1
  fi

  if [ ! -d "$PLUGIN_DIR/$plugin_name" ]; then
    echo "  Error: Plugin '$plugin_name' not installed"
    return 1
  fi

  echo "  Updating $plugin_name..."
  cd "$PLUGIN_DIR/$plugin_name"
  git fetch --quiet
  local old_commit=$(git rev-parse --short HEAD)
  git pull --quiet
  local new_commit=$(git rev-parse --short HEAD)

  if [ "$old_commit" != "$new_commit" ]; then
    echo "    Updated: $old_commit → $new_commit"
  else
    echo "    Already up to date"
  fi

  cd "$SCRIPT_DIR"
}

command_pin() {
  local plugin_name=$1
  local commit=$2

  if [ -z "$plugin_name" ] || [ -z "$commit" ]; then
    echo "Usage: $0 pin <plugin-name> <commit-hash>"
    exit 1
  fi

  # Check if plugin exists in manifest
  local repo=$(jq -r ".plugins[\"$plugin_name\"].repo" "$MANIFEST" 2>/dev/null)
  if [ "$repo" = "null" ] || [ -z "$repo" ]; then
    echo "Error: Plugin '$plugin_name' not found in manifest"
    exit 1
  fi

  # Update manifest
  jq ".plugins[\"$plugin_name\"].commit = \"$commit\"" "$MANIFEST" > "$MANIFEST.tmp"
  mv "$MANIFEST.tmp" "$MANIFEST"

  # Checkout the commit
  if [ -d "$PLUGIN_DIR/$plugin_name" ]; then
    cd "$PLUGIN_DIR/$plugin_name"
    echo "Checking out $plugin_name at $commit..."
    git fetch --quiet
    git checkout --quiet "$commit"
    echo "✓ Pinned $plugin_name to $commit"
  else
    echo "✓ Updated manifest. Run 'install' to apply changes."
  fi
}

command_list() {
  echo "Installed plugins:"
  echo ""

  local plugins=$(jq -r '.plugins | keys[]' "$MANIFEST")
  for plugin_name in $plugins; do
    local repo=$(jq -r ".plugins[\"$plugin_name\"].repo" "$MANIFEST")
    local pinned=$(jq -r ".plugins[\"$plugin_name\"].commit" "$MANIFEST")

    if [ -d "$PLUGIN_DIR/$plugin_name" ]; then
      cd "$PLUGIN_DIR/$plugin_name"
      local current=$(git rev-parse --short HEAD)
      local branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "detached")

      if [ "$pinned" = "latest" ]; then
        echo "  $plugin_name ($repo) - $current [$branch]"
      else
        echo "  $plugin_name ($repo) - $current [pinned: $pinned]"
      fi
    else
      echo "  $plugin_name ($repo) - NOT INSTALLED"
    fi
  done
}

# Build blink.cmp
command_build_blink() {
  if [ ! -d "$PLUGIN_DIR/blink.cmp" ]; then
    echo "Error: blink.cmp not installed"
    return 1
  fi

  if ! command -v cargo >/dev/null 2>&1; then
    echo "Error: cargo not found. Install Rust: curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh"
    return 1
  fi

  echo "Building blink.cmp..."
  cd "$PLUGIN_DIR/blink.cmp"
  cargo build --release

  # Detect OS and copy correct library extension
  if [[ "$OSTYPE" == "darwin"* ]]; then
    # macOS
    cp target/release/libblink_cmp_fuzzy.dylib lua/blink/cmp/fuzzy/rust.so
  else
    # Linux
    cp target/release/libblink_cmp_fuzzy.so lua/blink/cmp/fuzzy/rust.so
  fi

  echo "✓ Built successfully"
}

# Purge all plugins
command_purge() {
  # Resolve symlinks to find real plugin directory
  local real_plugin_dir
  if command -v realpath >/dev/null 2>&1; then
    real_plugin_dir=$(realpath "$PLUGIN_DIR" 2>/dev/null || echo "$PLUGIN_DIR")
  elif command -v readlink >/dev/null 2>&1; then
    # macOS doesn't have readlink -f, use different approach
    if [[ "$OSTYPE" == "darwin"* ]]; then
      real_plugin_dir=$(cd "$PLUGIN_DIR" 2>/dev/null && pwd -P || echo "$PLUGIN_DIR")
    else
      real_plugin_dir=$(readlink -f "$PLUGIN_DIR" 2>/dev/null || echo "$PLUGIN_DIR")
    fi
  else
    real_plugin_dir="$PLUGIN_DIR"
  fi

  echo "Plugin directory (resolved): $real_plugin_dir"

  if [ ! -d "$real_plugin_dir" ]; then
    echo "No plugins to purge (directory doesn't exist)"
    return 0
  fi

  echo ""
  echo "⚠️  This will DELETE all plugins from:"
  echo "    $real_plugin_dir"
  echo ""
  read -p "Are you sure? (type 'yes' to confirm): " confirm

  if [ "$confirm" = "yes" ]; then
    rm -rf "$real_plugin_dir"
    echo "✓ All plugins purged"
    echo ""
    echo "Run 'vpm i' to reinstall"
  else
    echo "Cancelled"
  fi
}

# Doctor command - diagnose setup issues
command_doctor() {
  echo "vpm doctor - checking setup..."
  echo ""

  local issues=0

  # Check nvim installation
  if command -v nvim >/dev/null 2>&1; then
    local nvim_version=$(nvim --version | head -1)
    echo "✓ Neovim installed: $nvim_version"
  else
    echo "✗ Neovim not found in PATH"
    ((issues++))
  fi

  # Check manifest exists
  if [ -f "$MANIFEST" ]; then
    echo "✓ Manifest found: $MANIFEST"
  else
    echo "✗ Manifest not found: $MANIFEST"
    ((issues++))
  fi

  # Check ~/.config/nvim setup
  if [ ! -e "$NVIM_CONFIG" ]; then
    echo "✗ ~/.config/nvim does not exist"
    echo "  → Run 'rcup -q' to set up symlinks"
    ((issues++))
  elif [ -L "$NVIM_CONFIG" ] && [ ! -L "$NVIM_CONFIG/init.lua" ]; then
    # Whole directory is a symlink (BAD)
    echo "✗ ~/.config/nvim is a single symlink to the repo"
    echo "  → This puts pack/ in your git repo (wrong!)"
    echo "  → Fix: rm ~/.config/nvim && rcup -q"
    ((issues++))
  elif [ -L "$NVIM_CONFIG/init.lua" ]; then
    # Individual files are symlinked (GOOD)
    echo "✓ ~/.config/nvim has individual file symlinks (correct)"
  else
    echo "⚠ ~/.config/nvim exists but setup unclear"
  fi

  # Check pack directory location
  if [ -d "$DOTFILES_NVIM/pack" ]; then
    echo "✗ pack/ directory found in git repo: $DOTFILES_NVIM/pack"
    echo "  → This should NOT be in your repo"
    echo "  → Fix: rm -rf $DOTFILES_NVIM/pack"
    ((issues++))
  else
    echo "✓ pack/ not in git repo (correct)"
  fi

  if [ -d "$PLUGIN_DIR" ]; then
    echo "✓ Plugin directory exists: $PLUGIN_DIR"

    # Check a sample plugin has correct remote
    if [ -d "$PLUGIN_DIR/telescope.nvim" ]; then
      local remote=$(cd "$PLUGIN_DIR/telescope.nvim" && git remote get-url origin 2>/dev/null)
      if [[ "$remote" == *"nvim-telescope/telescope.nvim"* ]]; then
        echo "✓ Plugin git remotes look correct"
      else
        echo "✗ Plugin has wrong git remote: $remote"
        echo "  → Plugins should point to their upstream repos"
        echo "  → Fix: vpm purge && vpm i"
        ((issues++))
      fi
    fi
  else
    echo "⚠ Plugin directory not found (run 'vpm i' to install)"
  fi

  # Check blink.cmp fuzzy library
  if [ -d "$PLUGIN_DIR/blink.cmp" ]; then
    local blink_lib=""
    if [[ "$OSTYPE" == "darwin"* ]]; then
      blink_lib="$PLUGIN_DIR/blink.cmp/lua/blink/cmp/fuzzy/rust.so"
    else
      blink_lib="$PLUGIN_DIR/blink.cmp/lua/blink/cmp/fuzzy/rust.so"
    fi

    if [ -f "$blink_lib" ] && [ ! -L "$blink_lib" ]; then
      echo "✓ blink.cmp fuzzy library compiled"
    elif [ -L "$blink_lib" ]; then
      echo "✗ blink.cmp fuzzy library is a symlink (wrong!)"
      echo "  → Fix: vpm purge && vpm i"
      ((issues++))
    else
      echo "⚠ blink.cmp fuzzy library not found"
      echo "  → Should auto-download on Mac (v1.10.1 has prebuilt binaries)"
      echo "  → If missing: vpm build-blink"
    fi
  fi

  # Summary
  echo ""
  if [ $issues -eq 0 ]; then
    echo "✓ All checks passed!"
  else
    echo "Found $issues issue(s) that need attention"
    exit 1
  fi
}

# Main command dispatcher
case "${1:-}" in
  install|i)
    command_install
    ;;
  update|u)
    command_update "$2"
    ;;
  pin|p)
    command_pin "$2" "$3"
    ;;
  list|l)
    command_list
    ;;
  build-blink)
    command_build_blink
    ;;
  purge)
    command_purge
    ;;
  doctor|d)
    command_doctor
    ;;
  *)
    echo "vpm - vim package manager"
    echo ""
    echo "Usage: vpm <command> [args]"
    echo ""
    echo "Commands:"
    echo "  install (i)         Install all plugins from manifest"
    echo "  list (l)            List installed plugins and versions"
    echo "  update (u) [plugin] Update all or specific plugin to latest"
    echo "  pin (p) <name> <h>  Pin plugin to specific commit"
    echo "  purge               Delete all plugins"
    echo ""
    echo "Troubleshooting:"
    echo "  doctor (d)          Check setup and diagnose issues"
    echo "  build-blink         Manually build blink.cmp (only if auto-download fails)"
    exit 1
    ;;
esac
